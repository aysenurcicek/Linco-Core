@{
    ViewData["Title"] = "Bilgi Sınırı";
    ViewData["HideLogin"] = true;
    ViewData["DisableLogoLink"] = true;
}

@section Scripts {
    <style>
        .level-btn {
            background-color: var(--lingo-bar-bg);
            color: white;
            border-radius: 50px;
            font-weight: 600;
            padding: 8px 25px;
            transition: all 0.3s ease;
            border: none;
        }
        .level-btn:hover, .level-btn.active, .level-btn:focus {
            background-color: #e63946;
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 8px 15px rgba(230, 57, 70, 0.3);
        }
        .topic-input {
            border-radius: 50px !important;
            padding: 15px 30px !important;
            font-size: 1.25rem;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            border: 2px solid transparent;
            transition: all 0.3s ease;
            width: 100%;
        }
        .topic-input:focus {
            border-color: var(--lingo-bar-bg);
            box-shadow: 0 10px 30px rgba(0, 163, 224, 0.15);
            outline: none;
        }
        .question-card {
            background-color: white;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            padding: 2rem;
            margin-bottom: 2rem;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        .question-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0, 163, 224, 0.15);
        }
        .question-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 8px;
            height: 100%;
            background-color: var(--lingo-bar-bg);
        }
        .question-number {
            font-size: 1.5rem;
            font-weight: bold;
            color: var(--lingo-title-blue);
            margin-bottom: 1rem;
        }
        .question-text {
            font-size: 1.25rem;
            color: #333;
            margin-bottom: 1.5rem;
            font-weight: 500;
        }
        .option-item {
            display: flex;
            align-items: center;
            padding: 12px 15px;
            margin-bottom: 10px;
            border-radius: 10px;
            background-color: #f8f9fa;
            cursor: pointer;
            transition: all 0.2s ease;
            border: 2px solid transparent;
        }
        .option-item:hover {
            background-color: #e9ecef;
        }
        .option-circle {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            border: 2px solid #adb5bd;
            margin-right: 15px;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: all 0.2s ease;
        }
        .option-item.selected {
            background-color: rgba(40, 167, 69, 0.1);
            border-color: #28a745;
        }
        .option-item.selected .option-circle {
            border-color: #28a745;
            background-color: #28a745;
        }
        .option-item.selected .option-circle::after {
            content: '';
            display: block;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background-color: white;
        }
        .option-text {
            font-size: 1.1rem;
            color: #495057;
            font-weight: 500;
        }
    </style>

    <script>
        let selectedLevel = '';
        let testQuestions = [];
        let userAnswers = {};

        $(document).ready(function() {
            $('.level-btn').click(function() {
                $('.level-btn').removeClass('active');
                $(this).addClass('active');
                selectedLevel = $(this).text();
            });

            $('#btnGenerate').click(function() {
                var topic = $('.topic-input').val();
                if(!topic || !selectedLevel) {
                    alert("Lütfen bir konu girin ve seviye seçin!");
                    return;
                }

                var btn = $(this);
                btn.prop('disabled', true).html('<i class="bi bi-hourglass-split me-2"></i> TEST OLUŞTURULUYOR... (20 Soru)');

                $('#statusAlert').removeClass('d-none');
                $('#questionsContainer').empty();
                $('#btnAnalyze').addClass('d-none');
                userAnswers = {};

                $.ajax({
                    url: '/Home/GenerateTest',
                    type: 'POST',
                    data: { topic: topic, level: selectedLevel },
                    success: function(res) {
                        btn.prop('disabled', false).html('<i class="bi bi-card-checklist me-2"></i> TEST OLUŞTUR');
                        $('#statusAlert').addClass('d-none');

                        if(res.success) {
                            try {
                                testQuestions = JSON.parse(res.data);
                                renderQuestions();
                                $('#btnAnalyze').removeClass('d-none');
                                // Save topic to sessionStorage for results
                                sessionStorage.setItem("testTopic", topic);
                            } catch(e) {
                                alert("Veri çözümlenirken hata oluştu.");
                            }
                        } else {
                            alert(res.message);
                        }
                    },
                    error: function() {
                        btn.prop('disabled', false).html('<i class="bi bi-card-checklist me-2"></i> TEST OLUŞTUR');
                        $('#statusAlert').addClass('d-none');
                        alert("Bir hata oluştu.");
                    }
                });
            });

            function renderQuestions() {
                let html = '';
                const labels = ['A', 'B', 'C', 'D'];
                
                testQuestions.forEach((q, index) => {
                    html += `
                        <div class="question-card">
                            <div class="question-number">Soru ${index + 1}</div>
                            <div class="question-text">${q.question}</div>
                            <div class="options-container" data-question-index="${index}">
                    `;
                    
                    q.options.forEach((opt, optIdx) => {
                        html += `
                            <div class="option-item" data-option-index="${optIdx}">
                                <div class="option-circle"></div>
                                <div class="option-text"><strong>${labels[optIdx]})</strong> ${opt}</div>
                            </div>
                        `;
                    });

                    html += `
                            </div>
                        </div>
                    `;
                });

                $('#questionsContainer').html(html);

                $('.option-item').click(function() {
                    let questionIndex = $(this).parent().data('question-index');
                    let optionIndex = $(this).data('option-index');
                    
                    // Remove selected visual from options in this question
                    $(this).parent().find('.option-item').removeClass('selected');
                    // Add selected visual to clicked
                    $(this).addClass('selected');
                    
                    // Store answer
                    userAnswers[questionIndex] = optionIndex;
                });
            }

            $('#btnAnalyze').click(function() {
                let dogru = 0;
                let yanlis = 0;
                let bos = 0;
                
                let testResults = [];

                testQuestions.forEach((q, idx) => {
                    let userAnswer = userAnswers[idx];
                    let isCorrect = false;
                    let isBlank = false;
                    
                    if(userAnswer === undefined) {
                        bos++;
                        isBlank = true;
                    } else if (userAnswer === q.correctAnswerIndex) {
                        dogru++;
                        isCorrect = true;
                    } else {
                        yanlis++;
                    }

                    testResults.push({
                        question: q,
                        userAnswerIndex: userAnswer,
                        isCorrect: isCorrect,
                        isBlank: isBlank
                    });
                });

                let puan = Math.round((dogru / testQuestions.length) * 100);
                
                let btn = $(this);
                btn.prop('disabled', true).html('<i class="bi bi-hourglass-split me-2"></i> KANALİZE EDİLİYOR...');

                // Send to server to save
                $.ajax({
                    url: '/Home/SaveTestResult',
                    type: 'POST',
                    data: {
                        dogru: dogru,
                        yanlis: yanlis,
                        bos: bos,
                        puan: puan,
                        konu: sessionStorage.getItem("testTopic") || 'Genel'
                    },
                    success: function(res) {
                        if (res.success) {
                            sessionStorage.setItem("testResultsData", JSON.stringify({
                                details: testResults,
                                stats: {
                                    dogru: dogru,
                                    yanlis: yanlis,
                                    bos: bos,
                                    puan: puan
                                }
                            }));
                            window.location.href = '/Home/BilgiSiniriResult';
                        } else {
                            alert(res.message);
                            btn.prop('disabled', false).html('<i class="bi bi-graph-up-arrow me-2"></i> SONUÇLARI ANALİZ ET');
                        }
                    },
                    error: function() {
                        alert("Sonuç kaydedilirken hata oluştu.");
                        btn.prop('disabled', false).html('<i class="bi bi-graph-up-arrow me-2"></i> SONUÇLARI ANALİZ ET');
                    }
                });
            });
        });
    </script>
}

<section class="lingo-section pt-5">
    <div class="container">
        <!-- Top Section -->
        <div class="row align-items-center justify-content-center mb-5 mt-4">
            <div class="col-lg-8 text-center" style="transition: all 0.3s ease; cursor: default;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                <h1 class="hero-title fw-bold" style="font-size: 2.5rem; margin-bottom: 1rem;">Bilgi Sınırı</h1>
                <p class="hero-text mb-0" style="font-size: 1.25rem; color: var(--lingo-text-gray);">
                    Kendi bilgilerini test etmek için konu ve seviye belirle, yapay zeka senin için 20 sorudan oluşan zorlu bir sınav hazırlasın. Sınırlarını zorlamaya hazır mısın?
                </p>
            </div>
        </div>

        <!-- Single Topic Input Area -->
        <div class="row justify-content-center mb-4">
            <div class="col-lg-6">
                <div class="position-relative">
                    <input type="text" class="form-control topic-input" placeholder="Test istediğiniz konuyu giriniz (Örn: Tenses, Animals, Technology...)" />
                </div>
            </div>
        </div>

        <!-- Level Buttons -->
        <div class="row justify-content-center mb-4">
            <div class="col-lg-8 text-center d-flex justify-content-center gap-2 flex-wrap">
                <button class="btn level-btn">A1</button>
                <button class="btn level-btn">A2</button>
                <button class="btn level-btn">B1</button>
                <button class="btn level-btn">B2</button>
                <button class="btn level-btn">C1</button>
            </div>
        </div>

        <!-- Generate Button -->
        <div class="row justify-content-center mb-5">
            <div class="col-auto">
                <button id="btnGenerate" class="btn rounded-pill shadow translator-btn" style="background-color: var(--lingo-title-blue); border-color: var(--lingo-title-blue);">
                    <i class="bi bi-card-checklist me-2"></i> TEST OLUŞTUR
                </button>
            </div>
        </div>

        <div id="statusAlert" class="alert alert-info text-center d-none" role="alert">
            <i class="bi bi-magic me-2"></i> Yapay zeka senin için 20 harika soru hazırlıyor... Bu birkaç saniye sürebilir!
        </div>

        <!-- Questions Rendering Container -->
        <div class="row justify-content-center">
            <div class="col-lg-10" id="questionsContainer">
                <!-- Questions injected here by JS -->
            </div>
        </div>

        <!-- Analyze Button (Hidden Initially) -->
        <div class="row justify-content-center mt-4 mb-5">
            <div class="col-auto">
                <button id="btnAnalyze" class="btn rounded-pill shadow translator-btn d-none" style="background-color: var(--lingo-bar-bg); border-color: var(--lingo-bar-bg); font-size: 1.25rem; padding: 12px 35px;">
                    <i class="bi bi-graph-up-arrow me-2"></i> SONUÇLARI ANALİZ ET
                </button>
            </div>
        </div>
    </div>
</section>
